{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nina.dev/schemas/api.manifest.schema.json",
  "title": "NINA API manifest (developer-declared endpoints)",
  "type": "object",
  "required": ["actions"],
  "additionalProperties": false,
  "properties": {
    "apis": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["baseUrl"],
        "additionalProperties": false,
        "properties": {
          "baseUrl": { "type": "string", "minLength": 1 },
          "description": { "type": "string" }
        }
      }
    },
    "actions": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/actionEndpoint" }
    }
  },
  "$defs": {
    "actionEndpoint": {
      "type": "object",
      "required": ["method", "path", "runtime", "description"],
      "additionalProperties": false,
      "properties": {
        "apiId": { "type": "string", "default": "default" },
        "method": { "type": "string", "enum": ["GET", "POST", "PUT", "PATCH", "DELETE"] },
        "path": { "type": "string", "minLength": 1 },
        "runtime": { "type": "string", "enum": ["server", "browser"] },
        "description": { "type": "string", "minLength": 3 },
        "parameters": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "type": { "type": "string" },
              "required": { "type": "boolean" },
              "description": { "type": "string" }
            }
          }
        },
        "bodyTemplate": { "type": "object" },
        "paramMap": { "type": "object", "additionalProperties": { "type": "string" } },
        "risk": { "type": "string", "enum": ["low", "medium", "high"] },
        "requiresAuth": { "type": "boolean" },
        "availableOn": { "type": "array", "items": { "type": "string" } },
        "uiSteps": {
          "type": "array",
          "items": { "type": "object" }
        }
      }
    }
  }
}
